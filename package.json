{
  "name": "@keel/workspace-root",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "depcruise": "depcruise packages --config configs/dependency-cruiser.cjs",
    "test": "vitest run",
    "verify": "pnpm lint && pnpm depcruise && pnpm typecheck && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^10.7.0",
    "fast-check": "^4.9.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
